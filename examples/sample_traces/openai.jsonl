{"type": "plan", "ts": 1781215080.4311395, "duration_ms": 0.0, "data": {"plan": "Now I'll aggregate order totals per customer."}}
{"type": "action", "ts": 1781215080.4321394, "duration_ms": 0.0, "data": {"tool": "execute_sql", "input": "{\"query\": \"SELECT c.name, SUM(oi.quantity * oi.price) AS ltv FROM customers c JOIN orders o ON o.customer_id=c.id JOIN order_items oi ON oi.order_id=o.id GROUP BY c.name ORDER BY ltv DESC LIMIT 1\"}"}}
